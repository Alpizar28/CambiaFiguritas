rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // users: perfil público de cada usuario (necesario para mostrar matches y eventos).
    // Solo contiene campos PUBLIC-SAFE. Campos sensibles (email, fcmToken, etc.) viven
    // en `users/{uid}/private/...` y solo el dueño puede leerlos.
    // Reputación, premium y billing son inmutables client-side (solo Cloud Functions con
    // admin SDK los pueden tocar).
    match /users/{uid} {
      allow read: if isSignedIn();
      // Create transitorio: aceptamos `email` y `fcmToken` aunque el cliente nuevo
      // ya NO los manda. Cuando 100% del tráfico tenga el bundle nuevo y se haya
      // corrido `functions/scripts/migrate-fcm-tokens.ts`, sacar el comentario y
      // re-agregar los `!('email' in ...)` / `!('fcmToken' in ...)`. Ver DEPLOY.md.
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 80;
      // Update propio (dueño) con allow-list explícita de campos mutables. Cualquier campo
      // nuevo agregado al schema queda automáticamente inmutable hasta que se sume aquí.
      // `email` y `fcmToken` están en la lista solo durante la transición F-DB-001:
      // el bundle nuevo nunca los mutará, pero clientes con bundle viejo todavía intentan.
      // Sacarlos cuando se confirme 0 tráfico legacy.
      allow update: if isOwner(uid)
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly([
                           'name',
                           'city',
                           'photoUrl',
                           'whatsapp',
                           'notifyOnMatch',
                           'privacyHideProgress',
                           'privacyHideRepeated',
                           'privacyAnonymous',
                           'shareable',
                           'lat',
                           'lng',
                           'userTimezone',
                           // transitionals — eliminar tras migración:
                           'email',
                           'fcmToken',
                         ]);
      allow delete: if isOwner(uid);

      // Subcollection: campos sensibles (fcmToken, etc). Owner-only read; backend-only write
      // (las Cloud Functions escriben directo desde admin SDK que bypassea rules, y el cliente
      // necesita poder escribir su propio fcmToken — lo permitimos con shape estricto).
      match /private/{docId} {
        allow read: if isOwner(uid);
        // Permitir al dueño escribir solo `fcmToken` (registro de push) y el timestamp.
        allow write: if isOwner(uid)
                     && request.resource.data.keys().hasOnly(['fcmToken', 'updatedAt'])
                     && (
                       !('fcmToken' in request.resource.data) ||
                       (request.resource.data.fcmToken is string &&
                        request.resource.data.fcmToken.size() <= 4096)
                     );
      }

      // Subcollection: votos de reputación.
      // Cliente NO escribe acá. Solo Cloud Function admin puede.
      // Cliente puede LEER su propio voto (para saber si ya votó a alguien).
      match /votes/{voterUid} {
        allow read: if isSignedIn() && request.auth.uid == voterUid;
        allow write: if false;
      }

      // Subcollection: snapshots diarios para timeline de progreso personal.
      // Solo el dueño puede leer/escribir su propia historia.
      match /dailyStats/{yyyymmdd} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
                      && request.resource.data.date is string
                      && request.resource.data.date.size() <= 10
                      && request.resource.data.ownedCount is int
                      && request.resource.data.ownedCount >= 0
                      && request.resource.data.ownedCount <= 1000;
        allow delete: if false;
      }

      // Subcollection: contador diario de matches consumidos. Backend-only.
      match /matchSlots/{day} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Subcollection: audit trail de entitlements premium. Backend-only.
      match /entitlements/{source} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Subcollection: historial de búsquedas de matches. Owner-only.
      // Cap 10 matches por batch (premium top); filterUsed enum.
      match /matchHistory/{batchId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.matches is list
                      && request.resource.data.matches.size() <= 10
                      && request.resource.data.filterUsed in ['mi_ciudad', '15km', '50km', 'todos']
                      && request.resource.data.createdAt is timestamp;
        allow update: if false;
        allow delete: if isOwner(uid);
      }
    }

    // orders: pagos en proceso (TiloPay, Play Billing). Lectura solo del dueño.
    // Escritura backend-only.
    match /orders/{orderId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // processedWebhooks: dedupe store for inbound webhooks (TiloPay etc.).
    // Backend-only. No client access at all.
    match /processedWebhooks/{key} {
      allow read, write: if false;
    }

    // userAlbums: estado del album por usuario. Lectura abierta a usuarios autenticados
    // (la usa findMatches para iterar sobre todos los albums). Escritura solo del dueño.
    match /userAlbums/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    // events: eventos públicos creados por usuarios.
    // Lectura abierta. Crear requiere auth y createdBy == uid del usuario.
    // Solo el creador puede editar/borrar.
    // Lat/lng deben estar bucketeados a 0.05° (~5km) — el cliente ya lo hace, pero la regla
    // lo refuerza rechazando coords con más de 2 decimales no-cero.
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 100
                    && request.resource.data.lat is number
                    && request.resource.data.lng is number
                    && request.resource.data.lat >= -90 && request.resource.data.lat <= 90
                    && request.resource.data.lng >= -180 && request.resource.data.lng <= 180
                    // Bucketing check: lat * 20 debe ser entero (0.05° steps).
                    && (request.resource.data.lat * 20) is int
                    && (request.resource.data.lng * 20) is int
                    && request.resource.data.date is string
                    && request.resource.data.type in ['intercambio', 'meetup', 'tienda']
                    && request.resource.data.cityName is string
                    && request.resource.data.cityName.size() > 0
                    && request.resource.data.cityName.size() <= 80
                    && request.resource.data.citySlug is string
                    && request.resource.data.citySlug.size() > 0
                    && request.resource.data.citySlug.size() <= 60
                    && (!('description' in request.resource.data) ||
                        (request.resource.data.description is string &&
                         request.resource.data.description.size() <= 500))
                    && (!('creatorName' in request.resource.data) ||
                        (request.resource.data.creatorName is string &&
                         request.resource.data.creatorName.size() <= 80));
      allow update: if isSignedIn()
                    && resource.data.createdBy == request.auth.uid
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 100
                    && (resource.data.citySlug == null ||
                        request.resource.data.citySlug == resource.data.citySlug)
                    && (resource.data.cityName == null ||
                        request.resource.data.cityName == resource.data.cityName)
                    && (!('description' in request.resource.data) ||
                        request.resource.data.description.size() <= 500);
      allow delete: if isSignedIn()
                    && resource.data.createdBy == request.auth.uid;
    }

    // reports: reportes de usuarios. Solo se pueden crear; lectura/edición sólo desde admin/backend.
    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.resource.data.reporterUid == request.auth.uid
                    && request.resource.data.targetUid is string
                    && request.resource.data.targetUid.size() > 0
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 500;
      allow read, update, delete: if false;
    }

    // Rankings agregados por Cloud Function. Lectura abierta (auth required), escritura solo backend.
    match /rankings/{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // tradeSessions: sesiones de intercambio presencial entre dos usuarios.
    // Documento transitorio (expira en ~10 min). Pareo via shortCode + QR.
    // Reglas:
    //   - read: cualquier signed-in (necesario para query de join por shortCode).
    //     El contenido es transitorio y de bajo riesgo (no datos sensibles).
    //   - create: solo el host de la sesión, con status inicial waiting,
    //     guestUid null y expiresAt acotado a now + 11 min.
    //   - update: solo participantes (host o guest); cada lado sólo puede tocar
    //     sus propios campos. hostUid, guestUid, shortCode, createdAt, expiresAt
    //     y tradeId son inmutables client-side. Setear guestUid (join) y commit
    //     final corren via Cloud Function callable (admin SDK).
    //   - delete: deshabilitado.
    match /tradeSessions/{sessionId} {
      allow read: if isSignedIn();
      // create: ahora la sesión nace via Cloud Function `createTradeSession`
      // (admin SDK), por lo que la creación client-side queda bloqueada.
      // Mantenemos la validación de shape para defensa en profundidad si
      // alguien intentara escribir directamente.
      allow create: if isSignedIn()
                    && request.resource.data.hostUid == request.auth.uid
                    && request.resource.data.guestUid == null
                    && request.resource.data.status == 'waiting'
                    && request.resource.data.shortCode is string
                    && request.resource.data.shortCode.size() == 6
                    && request.resource.data.hostName is string
                    && request.resource.data.hostName.size() <= 80
                    && (request.resource.data.hostPhotoUrl == null ||
                        request.resource.data.hostPhotoUrl is string)
                    && request.resource.data.hostStickers is list
                    && request.resource.data.hostStickers.size() <= 200
                    && request.resource.data.guestStickers is list
                    && request.resource.data.guestStickers.size() == 0
                    && request.resource.data.createdAt is number
                    && request.resource.data.createdAt <= request.time.toMillis()
                    && request.resource.data.expiresAt is number
                    && request.resource.data.expiresAt <= request.time.toMillis() + 11 * 60 * 1000
                    && request.resource.data.expiresAt > request.time.toMillis()
                    && request.resource.data.tradeId == null;
      allow update: if isSignedIn()
                    && (request.auth.uid == resource.data.hostUid ||
                        request.auth.uid == resource.data.guestUid)
                    && request.resource.data.hostUid == resource.data.hostUid
                    && request.resource.data.guestUid == resource.data.guestUid
                    && request.resource.data.shortCode == resource.data.shortCode
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.expiresAt == resource.data.expiresAt
                    && request.resource.data.tradeId == resource.data.tradeId
                    && request.resource.data.status in ['selecting', 'paired',
                                                          'host_confirmed', 'guest_confirmed',
                                                          'cancelled']
                    // Transition guard: estados terminales no se pueden revivir.
                    // Cada lado sí puede deshacer SU propia confirmación
                    // (host_confirmed → selecting solo si lo hace el host;
                    //  guest_confirmed → selecting solo si lo hace el guest).
                    && resource.data.status != 'cancelled'
                    && resource.data.status != 'completed'
                    && resource.data.status != 'expired'
                    && !(resource.data.status == 'host_confirmed'
                          && request.resource.data.status in ['selecting', 'paired']
                          && request.auth.uid != resource.data.hostUid)
                    && !(resource.data.status == 'guest_confirmed'
                          && request.resource.data.status in ['selecting', 'paired']
                          && request.auth.uid != resource.data.guestUid)
                    && (
                      // Host edita sólo su lado.
                      (request.auth.uid == resource.data.hostUid
                        && request.resource.data.guestStickers == resource.data.guestStickers
                        && request.resource.data.guestConfirmedAt == resource.data.guestConfirmedAt
                        && request.resource.data.hostStickers is list
                        && request.resource.data.hostStickers.size() <= 200)
                      ||
                      // Guest edita sólo su lado.
                      (request.auth.uid == resource.data.guestUid
                        && request.resource.data.hostStickers == resource.data.hostStickers
                        && request.resource.data.hostConfirmedAt == resource.data.hostConfirmedAt
                        && request.resource.data.guestStickers is list
                        && request.resource.data.guestStickers.size() <= 200)
                    );
      allow delete: if false;
    }

    // Locks transitorios para reserva atómica de shortCode y sesión activa
    // por usuario. Backend-only (admin SDK).
    match /tradeShortCodes/{shortCode} {
      allow read, write: if false;
    }
    match /tradeUserLocks/{uid} {
      allow read, write: if false;
    }

    // trades: historial inmutable de intercambios completados.
    // Lectura solo participantes. Escritura solo backend (Cloud Function commitTradeSession).
    match /trades/{tradeId} {
      allow read: if isSignedIn() && (
                    resource.data.uidA == request.auth.uid ||
                    resource.data.uidB == request.auth.uid
                  );
      allow write: if false;
    }

    // Por defecto, todo lo demás bloqueado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
