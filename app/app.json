{
  "expo": {
    "name": "CambiaFiguritas",
    "slug": "cambiafiguritas",
    "scheme": "cambiafiguritas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cambiafiguritas.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos tu ubicación para mostrarte usuarios cercanos con quienes intercambiar figuritas.",
        "NSCameraUsageDescription": "CambiaFiguritas usa la cámara para escanear códigos de figuritas. Las fotos no se guardan ni se envían."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "com.cambiafiguritas.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "cambiafiguritas.online",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "cambiafiguritas.web.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#0A0A0A"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos tu ubicación para mostrarte usuarios cercanos con quienes intercambiar figuritas."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "CambiaFiguritas usa la cámara para escanear códigos de figuritas. Las fotos no se guardan ni se envían.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "userTrackingUsageDescription": "Esto permite mostrar publicidad relevante y mantener la app gratuita."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "95b2d002-c701-4924-a031-653d20ca788c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/95b2d002-c701-4924-a031-653d20ca788c"
    }
  }
}
